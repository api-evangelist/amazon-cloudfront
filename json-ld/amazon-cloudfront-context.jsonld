      "@id": "cloudfront:create_time",
      "@type": "xsd:dateTime"
    },
    "invalidationBatch": {
      "@id": "cloudfront:invalidation_batch",
      "@type": "xsd:string"
    },
    "InvalidationBatch": "cloudfront:InvalidationBatch",
    "paths": {
      "@id": "cloudfront:paths",
      "@type": "xsd:string"
    },
